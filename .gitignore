# Dependencies
node_modules/

# Environment and secrets
.env
.env.*
*.pem
*.key

# AWS
.aws/
aws-credentials*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Build artifacts
dist/
tmp/

# Test output
test-results/
playwright-report/
.claude/

# Post-deploy IndexNow state — runtime artefacts, regenerated on each deploy.
# The snapshot is the local memory of "URLs we knew about last time"; if it is
# lost, re-run with --initial-publish once to rebuild without spamming.
.indexnow-snapshot.json
.indexnow-log.jsonl

# Meta audit output, regenerated each run
audit-meta.csv

# CWV baseline output, regenerated each run. Commit specific snapshots
# manually with `git add -f cwv-baseline.json` if you want to record a moment
# in time. Budgets in scripts/cwv-budgets.json are committed.
cwv-baseline.json
